{
  "hosting": {
    "public": "public",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      { "source": "/register/**", "destination": "/register/index.html" },
      { "source": "/donor/**", "destination": "/donor/index.html" },
      { "source": "/volunteer/**", "destination": "/volunteer/index.html" },
      { "source": "/org-admin/**", "destination": "/org-admin/index.html" },
      { "source": "/admin/**", "destination": "/admin/index.html" }
    ],
    "headers": [
      {
        "source": "/sw.js",
        "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default"
    }
  ]
}
