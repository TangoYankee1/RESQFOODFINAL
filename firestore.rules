rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false;
    }

    match /donations/{donationId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.donorId == request.auth.uid
        && request.resource.data.status == 'open'
        && request.resource.data.beneficiaryOrgId is string
        && request.resource.data.beneficiaryOrgId.size() > 0;
      allow update: if isSignedIn()
        && (
          resource.data.donorId == request.auth.uid
          || request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'status', 'volunteerId', 'claimedAt', 'completedAt',
            'pickedUpAt', 'enRouteAt', 'deliveredAt',
            'verifiedBy', 'verifiedAt', 'updatedAt'
          ])
        );
      allow delete: if false;
    }
  }
}
