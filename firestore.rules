rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ────────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function incomingData() {
      return request.resource.data;
    }

    function existingData() {
      return resource.data;
    }

    // ── users/{userId} ────────────────────────────────────────────────────
    match /users/{userId} {

      // Donors can create their own profile (and only with the required consent fields)
      allow create: if isOwner(userId)
        && incomingData().role == 'donor'
        && incomingData().keys().hasAll([
             'fullName', 'contactNumber', 'role',
             'liabilityWaiverSigned', 'privacyConsentSigned'
           ])
        && incomingData().liabilityWaiverSigned == true
        && incomingData().privacyConsentSigned  == true;

      // Owner can read their own profile; admins and volunteers can read
      // any profile (for mission board / coordination)
      allow read: if isSignedIn();

      // Owner can update, but may NOT change their own role (no escalation)
      allow update: if isOwner(userId)
        && incomingData().role == existingData().role;

      allow delete: if false;
    }

    // ── donations/{donationId} ────────────────────────────────────────────
    match /donations/{donationId} {

      // Donors can create donations for themselves, status must start as
      // "pending", and both safety flags must be set
      allow create: if isSignedIn()
        && incomingData().donorId       == request.auth.uid
        && incomingData().status        == 'pending'
        && incomingData().safetyDeclared   == true
        && incomingData().postingConfirmed == true;

      // Donors can read their own donations; volunteers/admins can read all
      allow read: if isSignedIn();

      // Donors can only cancel their OWN donations while still pending
      allow update: if isSignedIn()
        && existingData().donorId == request.auth.uid
        && existingData().status  == 'pending'
        && incomingData().status  == 'cancelled'
        // Prevent other field tampering on cancel
        && incomingData().diff(existingData()).affectedKeys()
             .hasOnly(['status', 'statusHistory', 'updatedAt'])

        // Volunteers and admins can advance status (handled via separate path below)
        || isSignedIn()
        && existingData().donorId != request.auth.uid
        && incomingData().diff(existingData()).affectedKeys()
             .hasOnly([
               'status', 'volunteerId', 'claimedAt', 'pickedUpAt',
               'enRouteAt', 'deliveredAt', 'verifiedBy', 'verifiedAt',
               'statusHistory', 'updatedAt'
             ]);

      allow delete: if false;
    }

  }
}
